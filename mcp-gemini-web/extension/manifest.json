{
  "manifest_version": 3,
  "name": "Gemini Bridge",
  "version": "0.1.0",
  "description": "Ponte entre o MCP local e o Gemini web. Dirige o Gemini no DOM, sem tocar no mouse/teclado.",
  "permissions": ["scripting", "tabs", "alarms", "downloads"],
  "host_permissions": ["https://gemini.google.com/*", "https://*.googleusercontent.com/*"],
  "background": { "service_worker": "background.js" },
  "content_scripts": [
    {
      "matches": ["https://gemini.google.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
