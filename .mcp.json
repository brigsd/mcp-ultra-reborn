{
  "mcpServers": {
    "gemini-web": {
      "command": "python",
      "args": ["mcp-gemini-web/gemini_mcp.py"]
    },
    "deepseek-web": {
      "command": "python",
      "args": ["mcp-deepseek-web/deepseek_mcp.py"]
    },
    "ia-local": {
      "command": "python",
      "args": ["-m", "mcp_qwen_coder.server"],
      "env": {
        "MCP_SHELL": "auto"
      }
    },
    "qwen-controller": {
      "command": "python",
      "args": ["mcp-qwen-controller/qwen_mcp.py"],
      "env": {
        "QWEN_CDP_HOST": "127.0.0.1",
        "QWEN_CDP_PORT": "9222"
      }
    }
  }
}
