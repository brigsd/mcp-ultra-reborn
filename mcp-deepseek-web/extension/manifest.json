{
  "manifest_version": 3,
  "name": "DeepSeek Bridge",
  "version": "0.1.0",
  "description": "Ponte entre o MCP local e o DeepSeek web. Dirige o DeepSeek no DOM, sem tocar no mouse/teclado.",
  "permissions": ["scripting", "tabs", "alarms"],
  "host_permissions": ["https://chat.deepseek.com/*"],
  "background": { "service_worker": "background.js" },
  "content_scripts": [
    {
      "matches": ["https://chat.deepseek.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
