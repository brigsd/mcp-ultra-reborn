# Copie para .env e ajuste conforme necessário.

# Transporte: stdio (cliente local) ou http (IA web pela rede)
MCP_TRANSPORT=stdio

# --- Apenas para MCP_TRANSPORT=http ---
MCP_HOST=127.0.0.1
MCP_PORT=8000
# Token Bearer exigido no HTTP. DEIXE definido se for expor à rede!
MCP_AUTH_TOKEN=

# --- Execução ---
# Shell: auto | cmd | powershell | bash | sh
MCP_SHELL=auto
MCP_DEFAULT_TIMEOUT=60
MCP_MAX_TIMEOUT=600
MCP_MAX_OUTPUT_CHARS=100000

# Diretório inicial da sessão (default: pasta onde o servidor é iniciado)
MCP_START_DIR=

# --- Segurança (opcional) ---
# Restringe a IA a esta árvore de diretórios (jail). Vazio = sem restrição.
MCP_ALLOWED_DIR=
# Padrões regex de comandos bloqueados, separados por vírgula. Vazio = sem bloqueio.
# Exemplo: MCP_BLOCKED_PATTERNS=rm\s+-rf\s+/,format\s+,mkfs
MCP_BLOCKED_PATTERNS=
